rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Fields: uid, email, displayName, role, createdAt
    //
    // Collection: availability
    // Fields: date, startTime, endTime, capacity, createdAt
    //
    // Collection: bookings
    // Fields: windowId, userId, userName, userEmail, startTime, endTime, status, createdAt
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         (request.auth.token.email == "timmyjn19@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'role']) &&
             data.uid is string &&
             data.email is string &&
             data.role in ['admin', 'client'];
    }

    function isValidAvailability(data) {
      return data.keys().hasAll(['date', 'startTime', 'endTime', 'capacity']) &&
             data.date is string &&
             data.startTime is string &&
             data.endTime is string &&
             data.capacity is int;
    }

    function isValidBooking(data) {
      return data.keys().hasAll(['windowId', 'userId', 'startTime', 'endTime', 'status']) &&
             data.windowId is string &&
             data.userId is string &&
             data.startTime is string &&
             data.endTime is string &&
             data.status in ['confirmed', 'cancelled'];
    }

    // Rules
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if isOwner(userId) && isValidUser(request.resource.data) && request.resource.data.role == resource.data.role;
      allow update: if isAdmin();
    }

    match /availability/{windowId} {
      allow read: if true;
      allow write: if isAdmin() && isValidAvailability(request.resource.data);
    }

    match /bookings/{bookingId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid && isValidBooking(request.resource.data);
      allow update: if (isOwner(resource.data.userId) || isAdmin()) && isValidBooking(request.resource.data);
      allow delete: if isAdmin();
    }
  }
}
